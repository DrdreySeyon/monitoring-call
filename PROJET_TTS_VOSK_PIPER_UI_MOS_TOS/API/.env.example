APP_ENV=dev

DATABASE_URL=sqlite:///./call_monitor.db

ARI_URL=http://127.0.0.1:8088/asterisk/ari
ARI_USER=ari_user
ARI_PASSWORD=password

AMI_ENABLED=false
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=ami_user
AMI_PASSWORD=password

API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000

# Use comma-separated origins in prod, for example:
# CORS_ORIGINS=http://127.0.0.1:8080,https://monitoring.example.local
CORS_ORIGINS=*

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Paris
SCHEDULER_JOBSTORE_ENABLED=true
